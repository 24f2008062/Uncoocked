// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {

  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")

}

model User {
  id              String         @id @default(cuid())
  role            String         @default("User")
  name            String?
  fullName        String?
  email           String?        @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  dob             String?
  department      String?
  clubAssociation String?
  portfolioUrl    String?
  interests       String?        // JSON serialized array of interests
  preferenceScore Float          @default(0)
  onboardingCompleted Boolean    @default(false)
  createdAt       DateTime       @default(now())
  registrations   Registration[]
  activities      UserActivity[]
  organizedEvents Event[]        @relation("OrganizedEvents")
  managedEvents   EventManager[]
}

model Event {
  id              String           @id // e.g. hackathon-2026
  title           String
  type            String // Fest, Party, Hackathon, etc.
  category        String?
  tags            String? // JSON string
  keywords        String? // JSON string
  popularityScore Float            @default(0)
  date            DateTime
  location        String
  zone            String?
  city            String           @default("Lucknow")
  state           String           @default("Uttar Pradesh")
  country         String           @default("India")
  description     String
  schedule        String? // Markdown
  prizePool       String? // Markdown
  bannerUrl       String?
  googleMapsUrl   String?
  ticketType      String           @default("Free") // Free, Paid
  price           Float?
  capacity        Int
  waitlistEnabled Boolean          @default(false)
  archived        Boolean          @default(false)
  status          String           @default("Active") // Active or Completed
  createdAt       DateTime         @default(now())
  
  organizerId     String?
  organizer       User?            @relation("OrganizedEvents", fields: [organizerId], references: [id])

  registrations   Registration[]
  bulletinUpdates BulletinUpdate[]
  activities      UserActivity[]
  ticketTiers     TicketTier[]
  coupons         Coupon[]
  analytics       EventAnalytic[]
  managers        EventManager[]
  activityLogs    EventActivityLog[]
}

model TicketTier {
  id          String   @id @default(uuid())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String
  name        String
  price       Float    @default(0)
  capacity    Int?
  soldCount   Int      @default(0)
  description String?
  registrations Registration[]

  @@index([eventId])
}

model Coupon {
  id          String   @id @default(uuid())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String
  code        String
  discountPct Float
  maxUses     Int?
  currentUses Int      @default(0)
  registrations Registration[]

  @@index([eventId])
}

model Registration {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId      String
  
  ticketTier   TicketTier? @relation(fields: [ticketTierId], references: [id])
  ticketTierId String?
  
  coupon       Coupon?     @relation(fields: [couponId], references: [id])
  couponId     String?
  
  status       String   @default("Pending") // Pending, Confirmed, Checked In
  checkInStatus Boolean  @default(false)
  teamName     String?
  track        String?
  registeredAt DateTime @default(now())
  logs         RegistrationLog[]

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model BulletinUpdate {
  id       String   @id @default(uuid())
  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId  String
  title    String
  content  String
  postedAt DateTime @default(now())

  @@index([eventId])
}

model UserActivity {
  id              String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId         String
  interactionType String   // VIEW, SAVE, REGISTER
  timestamp       DateTime @default(now())

  @@index([userId])
  @@index([eventId])
}

model EventAnalytic {
  id              String   @id @default(uuid())
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId         String
  date            DateTime @default(now()) // Can be used to track daily stats
  views           Int      @default(0)
  uniqueVisitors  Int      @default(0)
  registrations   Int      @default(0)
  attendance      Int      @default(0)
  revenue         Float    @default(0)

  @@index([eventId])
}

model EventManager {
  id              String   @id @default(uuid())
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId         String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  role            String   @default("Admin") // Owner, Admin, Moderator
  addedAt         DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
}

model RegistrationLog {
  id              String   @id @default(uuid())
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId  String
  action          String   // Status Change, Check In
  oldStatus       String?
  newStatus       String?
  timestamp       DateTime @default(now())
  performedBy     String?  // User ID who performed the action

  @@index([registrationId])
}

model EventActivityLog {
  id              String   @id @default(uuid())
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId         String
  action          String   // e.g., "Updated Content", "Changed Settings"
  details         String?
  performedBy     String   // User ID
  timestamp       DateTime @default(now())

  @@index([eventId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  eventId   String   // Links the chat message to a specific event page
  userName  String   // Name of the student who sent it
  userEmail String   // To identify them uniquely
  message   String
  createdAt DateTime @default(now())

  // If you have an Event model in your schema, you can optionally link them here
}

model Review {
  id        String   @id @default(cuid())
  userName  String
  userEmail String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}